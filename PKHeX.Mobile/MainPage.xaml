<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PKHeX.Mobile.MainPage"
             Title="PKHeX"
             BackgroundColor="#0B0F1E">

    <ScrollView BackgroundColor="#0B0F1E">
        <VerticalStackLayout Padding="24" Spacing="20" BackgroundColor="#0B0F1E">

            <Label Text="PKHeX"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#EEEEFF"
                   HorizontalOptions="Center"
                   Margin="0,28,0,0" />

            <Label Text="Pokémon Save Editor"
                   FontSize="14"
                   TextColor="#8888BB"
                   HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,16,0,0">
                <Button x:Name="LoadButton"
                        Text="Load Save File"
                        Clicked="OnLoadClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="14" Padding="16,10" />
                <Button Text="Settings"
                        Clicked="OnSettingsClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="14" Padding="16,10" />
                <Button x:Name="BoxButton"
                        Text="View Boxes"
                        IsVisible="False"
                        Clicked="OnBoxClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="14" Padding="16,10" />
                <Button x:Name="SearchButton"
                        Text="Search"
                        IsVisible="False"
                        Clicked="OnSearchClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="14" Padding="16,10" />
                <Button x:Name="GiftDBButton"
                        Text="Mystery Gifts"
                        IsVisible="False"
                        Clicked="OnGiftDBClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="14" Padding="16,10" />
                <Button x:Name="ExportButton"
                        Text="Export Save"
                        IsVisible="False"
                        Clicked="OnExportClicked"
                        BackgroundColor="#2D1B69" TextColor="#C0A0FF"
                        FontSize="14" Padding="16,10" />
            </HorizontalStackLayout>

            <!-- Error display -->
            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="#FF6060"
                   BackgroundColor="#1A0A0A"
                   Padding="12,8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Save file info card -->
            <Border x:Name="SaveInfoCard"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#1E2D45"
                    BackgroundColor="#111827"
                    Padding="20"
                    Margin="0,8,0,0">
                <VerticalStackLayout Spacing="10">

                    <Label x:Name="GameLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#EEEEFF" />

                    <BoxView HeightRequest="1"
                             Color="#1E2D45" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="8">

                        <Label Grid.Row="0" Grid.Column="0" Text="Trainer:"
                               TextColor="#8888BB" FontAttributes="Bold" />
                        <Label x:Name="TrainerLabel" Grid.Row="0" Grid.Column="1"
                               TextColor="#EEEEFF" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Trainer ID:"
                               TextColor="#8888BB" FontAttributes="Bold" />
                        <Label x:Name="IDLabel" Grid.Row="1" Grid.Column="1"
                               TextColor="#EEEEFF" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Play Time:"
                               TextColor="#8888BB" FontAttributes="Bold" />
                        <Label x:Name="PlaytimeLabel" Grid.Row="2" Grid.Column="1"
                               TextColor="#EEEEFF" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Storage:"
                               TextColor="#8888BB" FontAttributes="Bold" />
                        <Label x:Name="StorageLabel" Grid.Row="3" Grid.Column="1"
                               TextColor="#EEEEFF" />

                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
