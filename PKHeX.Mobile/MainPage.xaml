<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PKHeX.Mobile.MainPage"
             Title="PKHeX"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B0F1E">

    <Grid RowDefinitions="*,Auto" Padding="12,8">

        <!-- Save cards section -->
        <CollectionView x:Name="SaveCardsList" Grid.Row="0"
                        SelectionMode="Single"
                        BackgroundColor="Transparent"
                        SelectionChanged="OnSaveCardSelectionChanged">
            <CollectionView.EmptyView>
                <Label Text="No saves found. Add folders in Settings → Manage Folders."
                       TextColor="#8888BB" FontSize="14"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       Margin="24,60" HorizontalTextAlignment="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,4" StrokeShape="RoundRectangle 8" Padding="12,10"
                            BackgroundColor="#111827"
                            Stroke="Transparent" StrokeThickness="2">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#111827" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#141E30" />
                                            <Setter Property="Stroke" Value="#2A4870" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsLoaded}" Value="True">
                                <Setter Property="Stroke" Value="#80B4FF" />
                                <Setter Property="StrokeThickness" Value="2.5" />
                                <Setter Property="BackgroundColor" Value="#141E3A" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="56,*,Auto">
                            <!-- Game icon: real icon when available, colored badge fallback -->
                            <Grid Grid.Column="0" WidthRequest="48" HeightRequest="48"
                                  VerticalOptions="Center" HorizontalOptions="Start">
                                <!-- Fallback badge (always underneath) -->
                                <Border StrokeShape="RoundRectangle 6"
                                        BackgroundColor="{Binding GameColor}"
                                        IsVisible="{Binding HasNoIcon}" />
                                <Label Text="{Binding GameShortName}" TextColor="White" FontAttributes="Bold"
                                       FontSize="11" HorizontalOptions="Center" VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       IsVisible="{Binding HasNoIcon}" />
                                <!-- Real icon -->
                                <Image Source="{Binding IconSource}"
                                       Aspect="AspectFit"
                                       IsVisible="{Binding HasIcon}" />
                            </Grid>
                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding TrainerName}" FontAttributes="Bold" FontSize="15" TextColor="#EEEEFF" />
                                <Label Text="{Binding VersionLabel}" FontSize="12" TextColor="#8888BB" />
                                <Label Text="{Binding DetailLine}" FontSize="11" TextColor="#445566" />
                            </VerticalStackLayout>
                            <!-- Active indicator -->
                            <Label Grid.Column="2" Text="● ACTIVE"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#4F80FF"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsLoaded}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Action buttons and hint -->
        <VerticalStackLayout Grid.Row="1" Spacing="4" Margin="0,8,0,0">

            <!-- Gamepad hint -->
            <Label Text="↕ navigate  A select  B back"
                   FontSize="10" TextColor="#404060"
                   HorizontalOptions="End" Margin="0,0,0,4" />

            <Border x:Name="Row_Load" StyleId="Navigate"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="0">
                <Button Text="💾 Load from Boxes"
                        Clicked="OnLoadBoxesClicked"
                        BackgroundColor="Transparent" TextColor="#A0C0FF"
                        FontSize="15" Padding="12,10" HorizontalOptions="Fill" />
            </Border>

            <Border x:Name="Row_Search" StyleId="Navigate"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="0">
                <Button Text="🔍 Search Pokémon"
                        Clicked="OnSearchClicked"
                        BackgroundColor="Transparent" TextColor="#A0C0FF"
                        FontSize="15" Padding="12,10" HorizontalOptions="Fill" />
            </Border>

            <Border x:Name="Row_Gifts" StyleId="Navigate"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="0">
                <Button Text="🎁 Mystery Gifts"
                        Clicked="OnGiftsClicked"
                        BackgroundColor="Transparent" TextColor="#A0C0FF"
                        FontSize="15" Padding="12,10" HorizontalOptions="Fill" />
            </Border>

            <Border x:Name="Row_Export" StyleId="Action"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="0">
                <Button Text="📤 Export Save"
                        Clicked="OnExportClicked"
                        BackgroundColor="Transparent" TextColor="#A0C0FF"
                        FontSize="15" Padding="12,10" HorizontalOptions="Fill" />
            </Border>

            <Border x:Name="Row_Settings" StyleId="Navigate"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="0">
                <Button Text="⚙ Settings"
                        Clicked="OnSettingsClicked"
                        BackgroundColor="Transparent" TextColor="#A0C0FF"
                        FontSize="15" Padding="12,10" HorizontalOptions="Fill" />
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
