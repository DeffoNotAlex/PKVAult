<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:theme="clr-namespace:PKHeX.Mobile.Theme"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.MainPage"
             Title="PKVault"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource ThPageBg}">

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*" RowSpacing="2">

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  TOP SECTION — Hero: centered save card              -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="HeroPanel" Grid.Row="0"
              BackgroundColor="{DynamicResource ThPageBg}"
              MinimumHeightRequest="160">

            <!-- Animated dot grid background -->
            <skia:SKCanvasView x:Name="HeroGridCanvas"
                               PaintSurface="OnHeroGridPaint"
                               IsVisible="False" />

            <!-- Empty state: shown when no save is focused -->
            <VerticalStackLayout x:Name="HeroEmptyState"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="14" VerticalOptions="Center">
                    <Image Source="pkvault_icon.png"
                           WidthRequest="48" HeightRequest="48"
                           VerticalOptions="Center" />
                    <Label Text="PKVault"
                           FontFamily="QuicksandExtraBold" FontSize="36"
                           TextColor="{DynamicResource ThTextPrimary}" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Label Text="SAVE MANAGER"
                       FontFamily="NunitoBold" FontSize="11"
                       TextColor="{DynamicResource ThTextHint}" CharacterSpacing="3.5"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Active save hero — floating 3D card (hidden until a save is focused) -->
            <Grid x:Name="HeroPreview" IsVisible="False"
                  HorizontalOptions="Center" VerticalOptions="Center">

                <!-- Radial glow behind the card -->
                <Ellipse x:Name="HeroGlowEllipse"
                         WidthRequest="320" HeightRequest="90"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         Margin="0,30,0,0" Opacity="0.55">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                            <GradientStop x:Name="HeroGlow0" Color="#304F80FF" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- The card -->
                <Border x:Name="HeroCard"
                        StrokeShape="RoundRectangle 24"
                        BackgroundColor="{DynamicResource ThCardBg}"
                        Stroke="#334F80FF" StrokeThickness="1.5"
                        Padding="18,14">

                    <Grid ColumnDefinitions="Auto,*">

                        <!-- Faded large icon in background (right-aligned) -->
                        <Grid Grid.Column="0" Grid.ColumnSpan="2"
                              HorizontalOptions="End" VerticalOptions="Center"
                              WidthRequest="76" HeightRequest="76"
                              Opacity="0.07" Margin="0,0,4,0">
                            <Border x:Name="HeroBgIconGrad"
                                    StrokeShape="RoundRectangle 18" Stroke="Transparent"
                                    IsVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop x:Name="HeroBgGrad0" Color="#3A5080" Offset="0" />
                                        <GradientStop x:Name="HeroBgGrad1" Color="#5A70A0" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label x:Name="HeroBgBadgeText"
                                       FontFamily="QuicksandExtraBold" FontSize="28"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Border x:Name="HeroBgIconImgBorder"
                                    StrokeShape="RoundRectangle 18" Stroke="Transparent"
                                    IsVisible="False">
                                <Image x:Name="HeroBgIconImg" Aspect="AspectFill" />
                            </Border>
                        </Grid>

                        <!-- Left: game icon badge -->
                        <Grid Grid.Column="0" WidthRequest="64" HeightRequest="64"
                              VerticalOptions="Center" Margin="0,0,14,0">
                            <Border x:Name="HeroIconGrad"
                                    StrokeShape="RoundRectangle 16" Stroke="Transparent">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop x:Name="HeroBadgeGrad0" Color="#3A5080" Offset="0" />
                                        <GradientStop x:Name="HeroBadgeGrad1" Color="#5A70A0" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label x:Name="HeroBadgeText" Text=""
                                       FontFamily="QuicksandExtraBold" FontSize="18"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Border x:Name="HeroIconImgBorder"
                                    StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                    IsVisible="False">
                                <Image x:Name="HeroIconImg" Aspect="AspectFill" />
                            </Border>
                        </Grid>

                        <!-- Right: trainer info -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                            <Label x:Name="HeroTrainerName"
                                   FontFamily="NunitoExtraBold" FontSize="22"
                                   TextColor="{DynamicResource ThTextPrimary}" />
                            <Label x:Name="HeroGameLabel"
                                   FontFamily="Nunito" FontSize="12"
                                   TextColor="{DynamicResource ThTextSecondary}" />

                            <!-- Stats row -->
                            <HorizontalStackLayout Spacing="18" Margin="0,2,0,0">
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="TID" FontFamily="NunitoBold" FontSize="8"
                                           TextColor="{DynamicResource ThTextDim}" CharacterSpacing="0.8" />
                                    <Label x:Name="HeroTID" FontFamily="NunitoExtraBold" FontSize="13"
                                           TextColor="{DynamicResource ThTextPrimary}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="BOXES" FontFamily="NunitoBold" FontSize="8"
                                           TextColor="{DynamicResource ThTextDim}" CharacterSpacing="0.8" />
                                    <Label x:Name="HeroBoxes" FontFamily="NunitoExtraBold" FontSize="13"
                                           TextColor="{DynamicResource ThTextPrimary}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="PLAYTIME" FontFamily="NunitoBold" FontSize="8"
                                           TextColor="{DynamicResource ThTextDim}" CharacterSpacing="0.8" />
                                    <Label x:Name="HeroPlaytime" FontFamily="NunitoExtraBold" FontSize="13"
                                           TextColor="{DynamicResource ThTextPrimary}" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <!-- Active pill -->
                            <Border x:Name="HeroActivePill"
                                    StrokeShape="RoundRectangle 20"
                                    BackgroundColor="#1A34D990"
                                    Stroke="#4034D990" StrokeThickness="1"
                                    Padding="10,4" HorizontalOptions="Start"
                                    IsVisible="False">
                                <HorizontalStackLayout Spacing="5">
                                    <Ellipse Fill="#34D990" WidthRequest="6" HeightRequest="6"
                                             VerticalOptions="Center" />
                                    <Label Text="ACTIVE" FontFamily="NunitoBold" FontSize="9"
                                           TextColor="#34D990" CharacterSpacing="0.6"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  BOTTOM SECTION — Save list + Action bar               -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="BottomPanel" Grid.Row="1" RowDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource ThPageBg}">

            <!-- Header -->
            <Grid Padding="18,14,18,8" ColumnDefinitions="*,Auto">
                <Label Text="SAVE FILES"
                       FontFamily="Quicksand" FontSize="12"
                       TextColor="{DynamicResource ThTextDim}"
                       CharacterSpacing="1.5"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 6"
                        BackgroundColor="{DynamicResource ThBadgeBg}"
                        Stroke="Transparent"
                        Padding="10,3">
                    <Label x:Name="SaveCountLabel" Text="0 saves"
                           FontFamily="NunitoBold" FontSize="10"
                           TextColor="{DynamicResource ThTextHint}" />
                </Border>
            </Grid>

            <!-- Save card list -->
            <CollectionView x:Name="SaveCardsList" Grid.Row="1"
                            SelectionMode="Single"
                            BackgroundColor="Transparent"
                            Margin="14,0"
                            SelectionChanged="OnSaveCardSelectionChanged">
                <CollectionView.EmptyView>
                    <Label Text="No saves found. Add folders in Settings."
                           FontFamily="Nunito" FontSize="14"
                           TextColor="{DynamicResource ThTextSecondary}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Margin="24,60" HorizontalTextAlignment="Center" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Border x:Name="CardBorder"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{Binding CardBackground}"
                                    Stroke="{Binding CardStroke}"
                                    StrokeThickness="{Binding CardStrokeThickness}"
                                    Padding="0">
                                <Grid Padding="14,12" ColumnDefinitions="4,48,*,Auto">
                                    <!-- Accent stripe (left edge) -->
                                    <BoxView Grid.Column="0"
                                             Color="{Binding GameColorLight}"
                                             WidthRequest="3"
                                             VerticalOptions="FillAndExpand"
                                             Margin="-14,0,0,0"
                                             IsVisible="{Binding IsLoaded}" />

                                    <!-- Game badge -->
                                    <Grid Grid.Column="1" WidthRequest="48" HeightRequest="48"
                                          VerticalOptions="Center">
                                        <Border StrokeShape="RoundRectangle 13"
                                                Stroke="Transparent"
                                                IsVisible="{Binding HasNoIcon}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{Binding GameColorDark}" Offset="0" />
                                                    <GradientStop Color="{Binding GameColorLight}" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Label Text="{Binding GameShortName}" TextColor="White"
                                                   FontFamily="QuicksandExtraBold" FontSize="15"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   HorizontalTextAlignment="Center" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 13"
                                                Stroke="Transparent"
                                                IsVisible="{Binding HasIcon}">
                                            <Image Source="{Binding IconSource}" Aspect="AspectFill" />
                                        </Border>
                                    </Grid>

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="2" Margin="14,0,0,0" Spacing="1"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding TrainerName}"
                                               FontFamily="NunitoExtraBold" FontSize="16"
                                               TextColor="{Binding TextPrimary}" />
                                        <Label Text="{Binding VersionLabel}"
                                               FontFamily="Nunito" FontSize="12"
                                               TextColor="{Binding TextSecondary}" />
                                        <Label Text="{Binding DetailLine}"
                                               FontFamily="Nunito" FontSize="10.5"
                                               TextColor="{Binding TextDim}" />
                                    </VerticalStackLayout>

                                    <!-- Active indicator -->
                                    <Ellipse Grid.Column="3" Fill="#34D990"
                                             WidthRequest="9" HeightRequest="9"
                                             VerticalOptions="Center"
                                             IsVisible="{Binding IsLoaded}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Action bar -->
            <VerticalStackLayout Grid.Row="2" Padding="14,10,14,14" Spacing="10">

                <!-- Primary "Open Boxes" button -->
                <Border x:Name="Btn_OpenBoxes"
                        StrokeShape="RoundRectangle 14"
                        Stroke="Transparent" StrokeThickness="1.5"
                        Padding="0" HeightRequest="48">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C8E6FF" Offset="0" />
                            <GradientStop Color="#B0D4F8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenBoxesTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="Open Boxes"
                           FontFamily="NunitoExtraBold" FontSize="15"
                           TextColor="#1A5A96"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Secondary 4-tile grid -->
                <Grid x:Name="SecondaryGrid" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <!-- Search -->
                    <Border x:Name="Tile_Search" Grid.Column="0"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThCardBg}"
                            Stroke="{DynamicResource ThTileStroke}" StrokeThickness="1"
                            Padding="0" HeightRequest="70">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSearchTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                    BackgroundColor="{DynamicResource ThIconBgBlue}"
                                    WidthRequest="34" HeightRequest="34"
                                    HorizontalOptions="Center">
                                <Label Text="{x:Static theme:Ph.MagnifyingGlass}"
                                       FontFamily="Phosphor" FontSize="20" TextColor="#A78BFA"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Search" FontFamily="NunitoBold" FontSize="10"
                                   TextColor="{DynamicResource ThTextSecondary}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Gifts -->
                    <Border x:Name="Tile_Gifts" Grid.Column="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThCardBg}"
                            Stroke="{DynamicResource ThTileStroke}" StrokeThickness="1"
                            Padding="0" HeightRequest="70">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGiftsTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                    BackgroundColor="{DynamicResource ThIconBgPink}"
                                    WidthRequest="34" HeightRequest="34"
                                    HorizontalOptions="Center">
                                <Label Text="{x:Static theme:Ph.Gift}"
                                       FontFamily="Phosphor" FontSize="20" TextColor="#FF6B9D"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Gifts" FontFamily="NunitoBold" FontSize="10"
                                   TextColor="{DynamicResource ThTextSecondary}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Export -->
                    <Border x:Name="Tile_Export" Grid.Column="2"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThCardBg}"
                            Stroke="{DynamicResource ThTileStroke}" StrokeThickness="1"
                            Padding="0" HeightRequest="70">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExportTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                    BackgroundColor="{DynamicResource ThIconBgOrange}"
                                    WidthRequest="34" HeightRequest="34"
                                    HorizontalOptions="Center">
                                <Label Text="{x:Static theme:Ph.Export}"
                                       FontFamily="Phosphor" FontSize="20" TextColor="#FF9F43"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Export" FontFamily="NunitoBold" FontSize="10"
                                   TextColor="{DynamicResource ThTextSecondary}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Bank -->
                    <Border x:Name="Tile_Bank" Grid.Column="3"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThCardBg}"
                            Stroke="{DynamicResource ThTileStroke}" StrokeThickness="1"
                            Padding="0" HeightRequest="70">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBankTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                    BackgroundColor="{DynamicResource ThIconBgGreen}"
                                    WidthRequest="34" HeightRequest="34"
                                    HorizontalOptions="Center">
                                <Label Text="{x:Static theme:Ph.Bank}"
                                       FontFamily="PhosphorFill" FontSize="20" TextColor="#34D990"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Bank" FontFamily="NunitoBold" FontSize="10"
                                   TextColor="{DynamicResource ThTextSecondary}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Gamepad hints -->
                <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="{DynamicResource ThHintBg}"
                                Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="↕" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="{DynamicResource ThTextSecondary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Nav" FontFamily="Nunito" FontSize="10"
                               TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="{DynamicResource ThHintBg}"
                                Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="A" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#34D990"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Select" FontFamily="Nunito" FontSize="10"
                               TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="{DynamicResource ThHintBg}"
                                Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="B" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#FF6B9D"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Back" FontFamily="Nunito" FontSize="10"
                               TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="{DynamicResource ThHintBg}"
                                Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="X" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#A78BFA"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Search" FontFamily="Nunito" FontSize="10"
                               TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
