<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.GamePage"
             Title="PKHeX"
             Shell.NavBarIsVisible="False">

    <!-- Root: top screen (3*) / bottom screen (2*) — maps to dual physical screens on AYN Thor -->
    <Grid RowDefinitions="3*,2*" RowSpacing="0" BackgroundColor="#0A0A14">

        <!-- ══════════════════════════════════════════ -->
        <!--  TOP SCREEN — box grid                     -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*" BackgroundColor="#0A0A14">

            <!-- Box navigation header -->
            <Grid Grid.Row="0" ColumnDefinitions="52,*,52"
                  BackgroundColor="#0D0D1F" Padding="4,6">
                <Button Grid.Column="0" Text="◀ L"
                        x:Name="PrevBoxBtn"
                        Clicked="OnPrevBox"
                        BackgroundColor="#1A2040" TextColor="#A0B0FF"
                        FontSize="13" FontAttributes="Bold" Padding="0" />
                <Label  Grid.Column="1" x:Name="BoxNameLabel"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        TextColor="White" FontSize="16" FontAttributes="Bold" />
                <Button Grid.Column="2" Text="R ▶"
                        x:Name="NextBoxBtn"
                        Clicked="OnNextBox"
                        BackgroundColor="#1A2040" TextColor="#A0B0FF"
                        FontSize="13" FontAttributes="Bold" Padding="0" />
            </Grid>

            <!-- Box canvas -->
            <skia:SKCanvasView Grid.Row="1"
                               x:Name="BoxCanvas"
                               PaintSurface="OnBoxPaintSurface">
                <skia:SKCanvasView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoxTapped" />
                </skia:SKCanvasView.GestureRecognizers>
            </skia:SKCanvasView>

        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!--  BOTTOM SCREEN — context panel             -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Row="1" BackgroundColor="#0D0D1F" Padding="12,8">

            <!-- IDLE STATE -->
            <Grid x:Name="IdlePanel" IsVisible="True"
                  RowDefinitions="*,Auto">

                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">

                    <!-- Save info -->
                    <VerticalStackLayout Grid.Column="0"
                                         VerticalOptions="Center" Spacing="3">
                        <Label x:Name="TrainerNameLabel"
                               TextColor="#E0E8FF" FontSize="15" FontAttributes="Bold" />
                        <Label x:Name="SaveGameLabel"
                               TextColor="#7080B0" FontSize="12" />
                        <Label x:Name="BoxCountLabel"
                               TextColor="#7080B0" FontSize="12" />
                    </VerticalStackLayout>

                    <!-- Gamepad hint -->
                    <Label Grid.Column="1"
                           TextColor="#404060" FontSize="10"
                           HorizontalOptions="End" VerticalOptions="End"
                           Text="D-pad: move  A: select&#10;L/R: prev/next box" />
                </Grid>

                <!-- Nav buttons -->
                <HorizontalStackLayout Grid.Row="1"
                                        HorizontalOptions="Center" Spacing="10">
                    <Button Text="Search"   Clicked="OnSearchClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                            FontSize="13" Padding="14,8" />
                    <Button Text="Gifts"    Clicked="OnGiftsClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                            FontSize="13" Padding="14,8" />
                    <Button Text="Settings" Clicked="OnSettingsClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                            FontSize="13" Padding="14,8" />
                    <Button Text="Export"   Clicked="OnExportClicked"
                            BackgroundColor="#2D1B69" TextColor="#C0A0FF"
                            FontSize="13" Padding="14,8" />
                    <Button Text="☰ Menu"   Clicked="OnMenuClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                            FontSize="13" Padding="14,8" />
                </HorizontalStackLayout>

            </Grid>

            <!-- SELECTED STATE -->
            <Grid x:Name="SelectedPanel" IsVisible="False"
                  ColumnDefinitions="80,*,Auto">

                <!-- Sprite preview -->
                <skia:SKCanvasView Grid.Column="0"
                                   x:Name="PreviewCanvas"
                                   WidthRequest="72" HeightRequest="60"
                                   VerticalOptions="Center"
                                   PaintSurface="OnPreviewPaint" />

                <!-- PKM summary -->
                <VerticalStackLayout Grid.Column="1"
                                      VerticalOptions="Center"
                                      Spacing="3" Margin="8,0,0,0">
                    <Label x:Name="PkmNameLabel"
                           TextColor="White" FontSize="16" FontAttributes="Bold" />
                    <Label x:Name="PkmLevelLabel"
                           TextColor="#C0D0FF" FontSize="13" />
                    <Label x:Name="PkmNatureLabel"
                           TextColor="#8090C0" FontSize="12" />
                    <Label x:Name="PkmMovesLabel"
                           TextColor="#606090" FontSize="11"
                           LineBreakMode="WordWrap" MaxLines="2" />
                </VerticalStackLayout>

                <!-- Actions -->
                <VerticalStackLayout Grid.Column="2"
                                      VerticalOptions="Center"
                                      Spacing="8" Margin="8,0,0,0">
                    <Button Text="✎ Edit"
                            Clicked="OnEditClicked"
                            BackgroundColor="#3A1A60" TextColor="#D0A0FF"
                            FontSize="14" Padding="18,10" />
                    <Button Text="✕ Back"
                            Clicked="OnDeselectClicked"
                            BackgroundColor="#1A1A30" TextColor="#6060A0"
                            FontSize="12" Padding="12,7" />
                </VerticalStackLayout>

            </Grid>

        </Grid>

    </Grid>
</ContentPage>
