<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.GamePage"
             Shell.NavBarIsVisible="False">

    <!-- Root: top screen (stats) / bottom screen (box grid) -->
    <Grid RowDefinitions="*,*" RowSpacing="2" BackgroundColor="#050510">

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  TOP SCREEN — idle: trainer info  /  selected: stats  -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="#0D0D1F">

            <!-- ── IDLE STATE ── -->
            <Grid x:Name="TopIdlePanel" RowDefinitions="*,Auto" Padding="14,10">

                <!-- Trainer summary + hint -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="TrainerNameLabel"
                               TextColor="#E0E8FF" FontSize="18" FontAttributes="Bold" />
                        <Label x:Name="SaveGameLabel"  TextColor="#7080B0" FontSize="13" />
                        <Label x:Name="BoxCountLabel"  TextColor="#7080B0" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           TextColor="#303850" FontSize="10"
                           HorizontalOptions="End" VerticalOptions="End"
                           Text="A: select  B: main menu&#10;X: search  Y: gifts&#10;⊙: settings  ▶: export&#10;L/R: prev / next box" />
                </Grid>

                <!-- Nav buttons -->
                <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="10" Margin="0,0,0,4">
                    <Button Text="Search"   Clicked="OnSearchClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF" FontSize="13" Padding="14,8" />
                    <Button Text="Gifts"    Clicked="OnGiftsClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF" FontSize="13" Padding="14,8" />
                    <Button Text="Settings" Clicked="OnSettingsClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF" FontSize="13" Padding="14,8" />
                    <Button Text="Export"   Clicked="OnExportClicked"
                            BackgroundColor="#2D1B69" TextColor="#C0A0FF" FontSize="13" Padding="14,8" />
                    <Button Text="☰ Menu"   Clicked="OnMenuClicked"
                            BackgroundColor="#1D3A70" TextColor="#A0C0FF" FontSize="13" Padding="14,8" />
                </HorizontalStackLayout>

            </Grid>

            <!-- ── SELECTED STATE ── -->
            <Grid x:Name="TopSelectedPanel" IsVisible="False"
                  ColumnDefinitions="2*,3*">

                <!-- Left: animated sprite (WebView over static fallback) -->
                <Grid Grid.Column="0" BackgroundColor="#06060F">
                    <skia:SKCanvasView x:Name="PreviewCanvas"
                                       PaintSurface="OnPreviewPaint" />
                    <WebView x:Name="SpriteWebView"
                             BackgroundColor="#06060F"
                             IsVisible="False" />
                </Grid>

                <!-- Right: hex radar chart + info + buttons -->
                <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto" Padding="6,4">

                    <skia:SKCanvasView Grid.Row="0"
                                       x:Name="RadarCanvas"
                                       PaintSurface="OnRadarPaint" />

                    <Label Grid.Row="1"
                           x:Name="SelectedSpeciesLabel"
                           TextColor="#EEEEFF" FontSize="12" FontAttributes="Bold"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           Margin="0,2,0,0" />

                    <HorizontalStackLayout Grid.Row="2"
                                           HorizontalOptions="Center"
                                           Spacing="10" Margin="0,6,0,6">
                        <Button Text="✎ Edit"
                                Clicked="OnEditClicked"
                                BackgroundColor="#3A1A60" TextColor="#D0A0FF"
                                FontSize="13" Padding="18,9" />
                        <Button Text="✕ Back"
                                Clicked="OnDeselectClicked"
                                BackgroundColor="#1A1A30" TextColor="#6060A0"
                                FontSize="12" Padding="12,7" />
                    </HorizontalStackLayout>

                </Grid>

            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  BOTTOM SCREEN — box grid                             -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" BackgroundColor="#0A0A14">

            <!-- Box navigation header -->
            <Grid Grid.Row="0" ColumnDefinitions="52,*,52"
                  BackgroundColor="#0D0D1F" Padding="4,6">
                <Button Grid.Column="0" Text="◀ L"
                        x:Name="PrevBoxBtn" Clicked="OnPrevBox"
                        BackgroundColor="#1A2040" TextColor="#A0B0FF"
                        FontSize="13" FontAttributes="Bold" Padding="0" />
                <Label  Grid.Column="1" x:Name="BoxNameLabel"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        TextColor="White" FontSize="16" FontAttributes="Bold" />
                <Button Grid.Column="2" Text="R ▶"
                        x:Name="NextBoxBtn" Clicked="OnNextBox"
                        BackgroundColor="#1A2040" TextColor="#A0B0FF"
                        FontSize="13" FontAttributes="Bold" Padding="0" />
            </Grid>

            <!-- Box canvas -->
            <skia:SKCanvasView Grid.Row="1"
                               x:Name="BoxCanvas"
                               PaintSurface="OnBoxPaintSurface">
                <skia:SKCanvasView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoxTapped" />
                </skia:SKCanvasView.GestureRecognizers>
            </skia:SKCanvasView>

        </Grid>

    </Grid>
</ContentPage>
