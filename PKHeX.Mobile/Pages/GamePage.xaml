<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.GamePage"
             Shell.NavBarIsVisible="False">

    <!-- Root: top screen / bottom screen, with floating menu overlay -->
    <Grid x:Name="RootGrid" RowDefinitions="*,*" RowSpacing="2" BackgroundColor="#050510">

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  TOP SCREEN — idle: trainer info  /  selected: detail  -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="TopScreenPanel" Grid.Row="0" BackgroundColor="#070C1A">

            <!-- Background image -->
            <Image Source="sprite_bg.jpg" Aspect="AspectFill" />

            <!-- Background canvas overlay (gradients, ambient glow) -->
            <skia:SKCanvasView x:Name="TopBgCanvas"
                               PaintSurface="OnTopBgPaint" />

            <!-- ── IDLE STATE — Trainer Card ── -->
            <Grid x:Name="TopIdlePanel" Padding="20,14"
                  ColumnDefinitions="Auto,16,*,Auto,16,Auto">

                <!-- Trainer circle (game icon inside) -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 70"
                        Stroke="#0FFFFFFF" StrokeThickness="2"
                        WidthRequest="100" HeightRequest="100"
                        VerticalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="TrainerCircleGrad0" Color="#26394880" Offset="0" />
                            <GradientStop x:Name="TrainerCircleGrad1" Color="#1AA78BFA" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image x:Name="TrainerGameIcon" Aspect="AspectFit"
                           WidthRequest="60" HeightRequest="60"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Trainer info -->
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                    <Label x:Name="TrainerNameLabel"
                           FontFamily="NunitoExtraBold" FontSize="22"
                           TextColor="#EDF0FF" />
                    <Label x:Name="SaveGameLabel"
                           FontFamily="Nunito" FontSize="13"
                           TextColor="#8892B5" />
                    <!-- Stat row: TID / Pokédex / Playtime -->
                    <HorizontalStackLayout Spacing="20" Margin="0,6,0,0">
                        <VerticalStackLayout>
                            <Label Text="TID" FontFamily="NunitoBold" FontSize="9"
                                   TextColor="#3D4A6E" CharacterSpacing="0.8" />
                            <Label x:Name="TrainerTIDLabel"
                                   FontFamily="NunitoExtraBold" FontSize="14"
                                   TextColor="#EDF0FF" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="POKÉDEX" FontFamily="NunitoBold" FontSize="9"
                                   TextColor="#3D4A6E" CharacterSpacing="0.8" />
                            <Label x:Name="TrainerPokedexLabel"
                                   FontFamily="NunitoExtraBold" FontSize="14"
                                   TextColor="#EDF0FF" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="PLAYTIME" FontFamily="NunitoBold" FontSize="9"
                                   TextColor="#3D4A6E" CharacterSpacing="0.8" />
                            <Label x:Name="TrainerPlaytimeLabel"
                                   FontFamily="NunitoExtraBold" FontSize="14"
                                   TextColor="#EDF0FF" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Vertical divider -->
                <BoxView Grid.Column="3" WidthRequest="1" HeightRequest="90"
                         VerticalOptions="Center"
                         Color="#0FFFFFFF" />

                <!-- Box info (right-aligned) -->
                <VerticalStackLayout Grid.Column="5" VerticalOptions="Center" Spacing="2">
                    <Label Text="CURRENT BOX" FontFamily="NunitoBold" FontSize="9"
                           TextColor="#3D4A6E" CharacterSpacing="1"
                           HorizontalTextAlignment="End" />
                    <Label x:Name="IdleBoxNameLabel"
                           FontFamily="QuicksandExtraBold" FontSize="18"
                           TextColor="#EDF0FF"
                           HorizontalTextAlignment="End" />
                    <Label x:Name="IdleBoxFillLabel"
                           FontFamily="Nunito" FontSize="11"
                           TextColor="#8892B5"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>
            </Grid>

            <!-- ── SELECTED STATE — 3-column Pokémon detail ── -->
            <Grid x:Name="TopSelectedPanel" IsVisible="False"
                  ColumnDefinitions="3.5*,4.5*,3*" Padding="8,6">

                <!-- Column 0: Stat radar in frosted glass box -->
                <Border x:Name="RadarBorder"
                        Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="#60101828"
                        Stroke="#50FFFFFF"
                        StrokeThickness="1"
                        Margin="4"
                        VerticalOptions="Center">
                    <skia:SKCanvasView x:Name="RadarCanvas"
                                       PaintSurface="OnRadarPaint" />
                </Border>

                <!-- Column 1: Type badges + Sprite + Name plate -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="6">
                    <!-- Type badges -->
                    <HorizontalStackLayout x:Name="TypeBadgeRow" Grid.Row="0"
                                           HorizontalOptions="Center" Spacing="5"
                                           Margin="0,4,0,0" />

                    <!-- Animated sprite (WebView) / static fallback (Canvas) -->
                    <Grid Grid.Row="1">
                        <skia:SKCanvasView x:Name="PreviewCanvas"
                                           PaintSurface="OnPreviewPaint" />
                        <WebView x:Name="SpriteWebView"
                                 BackgroundColor="Transparent"
                                 IsVisible="False" />
                    </Grid>

                    <!-- Name plate -->
                    <VerticalStackLayout Grid.Row="2" HorizontalOptions="Center"
                                         Spacing="1" Margin="0,0,0,6">
                        <Label x:Name="DetailSpeciesName"
                               FontFamily="NunitoExtraBold" FontSize="15"
                               TextColor="#EDF0FF"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="DetailLevelNature"
                               FontFamily="Nunito" FontSize="10"
                               TextColor="#EDF0FF"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Column 2: Moves + Ability/Item -->
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                     Spacing="4" Padding="8,14,14,14">
                    <Label Text="MOVES" FontFamily="NunitoBold" FontSize="9"
                           TextColor="#EDF0FF" CharacterSpacing="1.2"
                           Margin="0,0,0,4" />

                    <!-- 4 move rows -->
                    <Border x:Name="MoveRow0" StrokeShape="RoundRectangle 10"
                            BackgroundColor="#50101828" Stroke="#50FFFFFF" StrokeThickness="1"
                            Padding="8,6">
                        <Grid ColumnDefinitions="10,*,Auto">
                            <Ellipse x:Name="MoveDot0" Grid.Column="0" Fill="#A8A878"
                                     WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Margin="6,0,0,0">
                                <Label x:Name="MoveName0" FontFamily="NunitoBold" FontSize="12"
                                       TextColor="#EDF0FF" />
                                <Label x:Name="MoveCat0" FontFamily="Nunito" FontSize="9"
                                       TextColor="#3D4A6E" />
                            </VerticalStackLayout>
                            <Label x:Name="MovePP0" Grid.Column="2"
                                   FontFamily="NunitoBold" FontSize="10"
                                   TextColor="#EDF0FF" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border x:Name="MoveRow1" StrokeShape="RoundRectangle 10"
                            BackgroundColor="#50101828" Stroke="#50FFFFFF" StrokeThickness="1"
                            Padding="8,6">
                        <Grid ColumnDefinitions="10,*,Auto">
                            <Ellipse x:Name="MoveDot1" Grid.Column="0" Fill="#A8A878"
                                     WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Margin="6,0,0,0">
                                <Label x:Name="MoveName1" FontFamily="NunitoBold" FontSize="12"
                                       TextColor="#EDF0FF" />
                                <Label x:Name="MoveCat1" FontFamily="Nunito" FontSize="9"
                                       TextColor="#3D4A6E" />
                            </VerticalStackLayout>
                            <Label x:Name="MovePP1" Grid.Column="2"
                                   FontFamily="NunitoBold" FontSize="10"
                                   TextColor="#EDF0FF" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border x:Name="MoveRow2" StrokeShape="RoundRectangle 10"
                            BackgroundColor="#50101828" Stroke="#50FFFFFF" StrokeThickness="1"
                            Padding="8,6">
                        <Grid ColumnDefinitions="10,*,Auto">
                            <Ellipse x:Name="MoveDot2" Grid.Column="0" Fill="#A8A878"
                                     WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Margin="6,0,0,0">
                                <Label x:Name="MoveName2" FontFamily="NunitoBold" FontSize="12"
                                       TextColor="#EDF0FF" />
                                <Label x:Name="MoveCat2" FontFamily="Nunito" FontSize="9"
                                       TextColor="#3D4A6E" />
                            </VerticalStackLayout>
                            <Label x:Name="MovePP2" Grid.Column="2"
                                   FontFamily="NunitoBold" FontSize="10"
                                   TextColor="#EDF0FF" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border x:Name="MoveRow3" StrokeShape="RoundRectangle 10"
                            BackgroundColor="#50101828" Stroke="#50FFFFFF" StrokeThickness="1"
                            Padding="8,6">
                        <Grid ColumnDefinitions="10,*,Auto">
                            <Ellipse x:Name="MoveDot3" Grid.Column="0" Fill="#A8A878"
                                     WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Margin="6,0,0,0">
                                <Label x:Name="MoveName3" FontFamily="NunitoBold" FontSize="12"
                                       TextColor="#EDF0FF" />
                                <Label x:Name="MoveCat3" FontFamily="Nunito" FontSize="9"
                                       TextColor="#3D4A6E" />
                            </VerticalStackLayout>
                            <Label x:Name="MovePP3" Grid.Column="2"
                                   FontFamily="NunitoBold" FontSize="10"
                                   TextColor="#EDF0FF" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#30FFFFFF" Margin="0,4" />

                    <!-- Ability / Item -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout>
                            <Label Text="ABILITY" FontFamily="NunitoBold" FontSize="8"
                                   TextColor="#EDF0FF" CharacterSpacing="0.6" />
                            <Label x:Name="DetailAbility" FontFamily="NunitoBold" FontSize="11"
                                   TextColor="#EDF0FF" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="ITEM" FontFamily="NunitoBold" FontSize="8"
                                   TextColor="#EDF0FF" CharacterSpacing="0.6" />
                            <Label x:Name="DetailItem" FontFamily="NunitoBold" FontSize="11"
                                   TextColor="#EDF0FF" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>

            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  BOTTOM SCREEN — box grid                             -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" BackgroundColor="#070C1A">

            <!-- Box navigation header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
                  Padding="16,12,16,8">
                <!-- L button -->
                <Border x:Name="PrevBoxBtn" StrokeShape="RoundRectangle 10"
                        BackgroundColor="#131B35" Stroke="#0D0D0D0D" StrokeThickness="1"
                        WidthRequest="40" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPrevBox" />
                    </Border.GestureRecognizers>
                    <Label Text="◀" FontSize="14" TextColor="#8892B5"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Box title -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="1">
                    <Label x:Name="BoxNameLabel"
                           FontFamily="QuicksandExtraBold" FontSize="18"
                           TextColor="#EDF0FF"
                           HorizontalTextAlignment="Center" />
                    <Label Text="R-Stick L/R  |  R1/L1 Bank" FontFamily="Nunito" FontSize="9"
                           TextColor="#283456"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- R button -->
                <Border x:Name="NextBoxBtn" Grid.Column="2"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#131B35" Stroke="#0D0D0D0D" StrokeThickness="1"
                        WidthRequest="40" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNextBox" />
                    </Border.GestureRecognizers>
                    <Label Text="▶" FontSize="14" TextColor="#8892B5"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Box canvas -->
            <skia:SKCanvasView Grid.Row="1"
                               x:Name="BoxCanvas"
                               PaintSurface="OnBoxPaintSurface"
                               EnableTouchEvents="False">
                <skia:SKCanvasView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoxTapped" />
                </skia:SKCanvasView.GestureRecognizers>
            </skia:SKCanvasView>

            <!-- Info bar -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="16,8,16,12">
                <!-- Slot info -->
                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label x:Name="InfoSpeciesNum"
                           FontFamily="Nunito" FontSize="12"
                           TextColor="#8892B5" />
                    <Label x:Name="InfoSpeciesName"
                           FontFamily="NunitoBold" FontSize="12"
                           TextColor="#EDF0FF" />
                </HorizontalStackLayout>

                <!-- Gamepad hints -->
                <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="3">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="#0AFFFFFF" Stroke="#0FFFFFFF" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="A" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#34D990"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Select" FontFamily="Nunito" FontSize="10" TextColor="#3D4A6E"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="3">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="#0AFFFFFF" Stroke="#0FFFFFFF" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="Y" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#6BABFF"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Grab" FontFamily="Nunito" FontSize="10" TextColor="#3D4A6E"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="3">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="#0AFFFFFF" Stroke="#0FFFFFFF" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="B" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#FF6B9D"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Back" FontFamily="Nunito" FontSize="10" TextColor="#3D4A6E"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="3">
                        <Border StrokeShape="RoundRectangle 5"
                                BackgroundColor="#0AFFFFFF" Stroke="#0FFFFFFF" StrokeThickness="1"
                                WidthRequest="20" HeightRequest="20">
                            <Label Text="≡" FontFamily="NunitoExtraBold" FontSize="9"
                                   TextColor="#F0C040"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Save" FontFamily="Nunito" FontSize="10" TextColor="#3D4A6E"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  FLOATING ACTION MENU (Start button)                  -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="ActionMenuOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#AA000818">
            <Border HorizontalOptions="Center" VerticalOptions="Center"
                    BackgroundColor="#0D1528" Stroke="#2A3F70"
                    StrokeShape="RoundRectangle 14" Padding="0"
                    MinimumWidthRequest="220">
                <VerticalStackLayout Spacing="0">

                    <!-- Menu title -->
                    <Label Text="Save / Export"
                           TextColor="#6070A0" FontSize="11"
                           HorizontalOptions="Center"
                           Margin="0,10,0,8" />

                    <!-- Save option -->
                    <Border x:Name="MenuItem_Save"
                            BackgroundColor="#1A3A1A" Stroke="Transparent"
                            StrokeShape="RoundRectangle 0" Padding="20,14"
                            Margin="8,0,8,4">
                        <Label Text="💾  Save to original file"
                               TextColor="#80DD80" FontSize="14"
                               HorizontalOptions="Center" />
                    </Border>

                    <!-- Export option -->
                    <Border x:Name="MenuItem_Export"
                            BackgroundColor="#1D1040" Stroke="Transparent"
                            StrokeShape="RoundRectangle 0" Padding="20,14"
                            Margin="8,0,8,10">
                        <Label Text="⬆  Export to new file"
                               TextColor="#9080CC" FontSize="14"
                               HorizontalOptions="Center" />
                    </Border>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
