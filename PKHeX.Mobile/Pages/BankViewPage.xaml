<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:theme="clr-namespace:PKHeX.Mobile.Theme"
             x:Class="PKHeX.Mobile.Pages.BankViewPage"
             BackgroundColor="{DynamicResource ThPageBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header: box navigation ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,12,16,8">
            <Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="{DynamicResource ThCardBg}"
                    Stroke="{DynamicResource ThNavBtnStroke}" StrokeThickness="1"
                    WidthRequest="40" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPrevBoxTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{x:Static theme:Ph.CaretLeft}" FontFamily="Phosphor"
                       FontSize="18" TextColor="{DynamicResource ThTextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="1">
                <Label x:Name="BoxNameLabel" FontFamily="QuicksandExtraBold" FontSize="18"
                       TextColor="{DynamicResource ThTextPrimary}" HorizontalTextAlignment="Center" />
                <Label x:Name="BoxIndexLabel" FontFamily="Nunito" FontSize="9"
                       TextColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border Grid.Column="2" StrokeShape="RoundRectangle 10"
                    BackgroundColor="{DynamicResource ThCardBg}"
                    Stroke="{DynamicResource ThNavBtnStroke}" StrokeThickness="1"
                    WidthRequest="40" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextBoxTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{x:Static theme:Ph.CaretRight}" FontFamily="Phosphor"
                       FontSize="18" TextColor="{DynamicResource ThTextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- ── Main: radar | sprite | info/moves ── -->
        <Grid Grid.Row="1" ColumnDefinitions="2.5*,3.5*,3*" Padding="8,4">

            <!-- Col 0: Stat radar  /  Compatibility list (toggled by X) -->
            <Grid Grid.Column="0">
                <!-- Radar (default) -->
                <Border x:Name="RadarBorder"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{DynamicResource ThRadarBg}"
                        Stroke="{DynamicResource ThRadarStroke}"
                        StrokeThickness="1"
                        Margin="4"
                        VerticalOptions="Center">
                    <skia:SKCanvasView x:Name="RadarCanvas" PaintSurface="OnRadarPaint" />
                </Border>

                <!-- Compatibility list (shown on X) -->
                <Border x:Name="CompatPanel" IsVisible="False"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{DynamicResource ThRadarBg}"
                        Stroke="{DynamicResource ThRadarStroke}"
                        StrokeThickness="1"
                        Margin="4"
                        VerticalOptions="Fill">
                    <ScrollView>
                        <VerticalStackLayout x:Name="CompatList"
                                             Padding="10,8" Spacing="5">
                            <Label Text="SAVES" FontFamily="NunitoBold" FontSize="8"
                                   TextColor="{DynamicResource ThTextDim}"
                                   CharacterSpacing="1.2" Margin="0,0,0,2" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>

            <!-- Col 1: HOME sprite -->
            <Grid Grid.Column="1" Margin="4">
                <Image x:Name="HomeSpriteImage"
                       Aspect="AspectFit"
                       VerticalOptions="Fill"
                       HorizontalOptions="Fill" />
            </Grid>

            <!-- Col 2: Info panel / Moves panel (toggled by X) -->
            <Grid Grid.Column="2" Margin="4,0,8,0">

                <!-- Info view (default) -->
                <VerticalStackLayout x:Name="InfoPanel" VerticalOptions="Center" Spacing="7">
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="SpeciesNum" FontFamily="Nunito" FontSize="13"
                               TextColor="{DynamicResource ThTextSecondary}" VerticalOptions="Center" />
                        <Label x:Name="SpeciesName" FontFamily="QuicksandExtraBold" FontSize="20"
                               TextColor="{DynamicResource ThTextPrimary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label x:Name="LevelLabel" FontFamily="NunitoBold" FontSize="15"
                           TextColor="{DynamicResource ThTextSecondary}" />
                    <Label x:Name="ShinyLabel" Text="✦ Shiny" FontFamily="NunitoBold" FontSize="13"
                           TextColor="#F0C040" IsVisible="False" />
                    <Label x:Name="OTLabel" FontFamily="Nunito" FontSize="12"
                           TextColor="{DynamicResource ThTextDim}" />
                    <Label x:Name="DepositLabel" FontFamily="Nunito" FontSize="11"
                           TextColor="{DynamicResource ThTextHint}" />
                </VerticalStackLayout>

                <!-- Moves view (X to toggle) -->
                <VerticalStackLayout x:Name="MovesPanel" IsVisible="False"
                                     VerticalOptions="Center" Spacing="6">
                    <Label Text="MOVES" FontFamily="NunitoBold" FontSize="9"
                           TextColor="{DynamicResource ThTextDim}" CharacterSpacing="1.2"
                           Margin="0,0,0,2" />
                    <Border x:Name="MoveRow0" StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThMoveRowBg}"
                            Stroke="{DynamicResource ThMoveRowStroke}" StrokeThickness="1"
                            Padding="10,7">
                        <Label x:Name="MoveLabel0" FontFamily="NunitoBold" FontSize="12"
                               TextColor="{DynamicResource ThTextPrimary}" />
                    </Border>
                    <Border x:Name="MoveRow1" StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThMoveRowBg}"
                            Stroke="{DynamicResource ThMoveRowStroke}" StrokeThickness="1"
                            Padding="10,7">
                        <Label x:Name="MoveLabel1" FontFamily="NunitoBold" FontSize="12"
                               TextColor="{DynamicResource ThTextPrimary}" />
                    </Border>
                    <Border x:Name="MoveRow2" StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThMoveRowBg}"
                            Stroke="{DynamicResource ThMoveRowStroke}" StrokeThickness="1"
                            Padding="10,7">
                        <Label x:Name="MoveLabel2" FontFamily="NunitoBold" FontSize="12"
                               TextColor="{DynamicResource ThTextPrimary}" />
                    </Border>
                    <Border x:Name="MoveRow3" StrokeShape="RoundRectangle 8"
                            BackgroundColor="{DynamicResource ThMoveRowBg}"
                            Stroke="{DynamicResource ThMoveRowStroke}" StrokeThickness="1"
                            Padding="10,7">
                        <Label x:Name="MoveLabel3" FontFamily="NunitoBold" FontSize="12"
                               TextColor="{DynamicResource ThTextPrimary}" />
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Grid>

        <!-- ── Hint bar ── -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center"
                               Spacing="20" Padding="0,6,0,12">
            <HorizontalStackLayout Spacing="4">
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="A" FontFamily="NunitoExtraBold" FontSize="9" TextColor="#34D990"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Add" FontFamily="Nunito" FontSize="11"
                       TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="4">
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="Y" FontFamily="NunitoExtraBold" FontSize="9" TextColor="#FCD34D"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Delete" FontFamily="Nunito" FontSize="11"
                       TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="4">
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="X" FontFamily="NunitoExtraBold" FontSize="9" TextColor="#A78BFA"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Moves" FontFamily="Nunito" FontSize="11"
                       TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="4">
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="B" FontFamily="NunitoExtraBold" FontSize="9" TextColor="#FF6B9D"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Back" FontFamily="Nunito" FontSize="11"
                       TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="4">
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="L1" FontFamily="NunitoExtraBold" FontSize="7" TextColor="#4FC3F7"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border StrokeShape="RoundRectangle 5"
                        BackgroundColor="{DynamicResource ThHintBg}"
                        Stroke="{DynamicResource ThHintStroke}" StrokeThickness="1"
                        WidthRequest="22" HeightRequest="22">
                    <Label Text="R1" FontFamily="NunitoExtraBold" FontSize="7" TextColor="#4FC3F7"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Box" FontFamily="Nunito" FontSize="11"
                       TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </HorizontalStackLayout>

        <!-- ── Pokémon picker overlay (A on empty slot) ── -->
        <Grid x:Name="PickerOverlay"
              Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#CC000020">
            <Border HorizontalOptions="Fill" VerticalOptions="Fill"
                    Margin="12"
                    BackgroundColor="{DynamicResource ThActionMenuPanel}"
                    Stroke="{DynamicResource ThActionMenuStroke}"
                    StrokeShape="RoundRectangle 16"
                    Padding="0">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Title row -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="12,12,12,8">
                        <Border x:Name="PickerBackBtn"
                                StrokeShape="RoundRectangle 8"
                                BackgroundColor="{DynamicResource ThHintBg}"
                                Stroke="{DynamicResource ThHintStroke}"
                                IsVisible="False" Padding="10,4">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPickerBackTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="← Back" FontFamily="NunitoBold" FontSize="11"
                                   TextColor="{DynamicResource ThTextSecondary}"/>
                        </Border>
                        <Label Grid.Column="1" x:Name="PickerTitle"
                               Text="Choose Generation"
                               FontFamily="NunitoBold" FontSize="14"
                               TextColor="{DynamicResource ThTextPrimary}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Generation selector (3×3 grid, populated in code) -->
                    <Grid Grid.Row="1" x:Name="GenSelectorGrid"
                          RowDefinitions="*,*,*" ColumnDefinitions="*,*,*"
                          Padding="12" RowSpacing="8" ColumnSpacing="8"/>

                    <!-- Species grid (hidden until gen selected) -->
                    <ScrollView Grid.Row="1" x:Name="SpeciesScroll" IsVisible="False">
                        <FlexLayout x:Name="SpeciesGrid"
                                    Wrap="Wrap" Direction="Row"
                                    JustifyContent="Start"
                                    AlignContent="Start"
                                    Padding="8" />
                    </ScrollView>

                    <!-- Hint bar -->
                    <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center"
                                           Spacing="16" Padding="0,6,0,12">
                        <HorizontalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{DynamicResource ThHintBg}"
                                    Stroke="{DynamicResource ThHintStroke}"
                                    WidthRequest="22" HeightRequest="22">
                                <Label Text="A" FontFamily="NunitoExtraBold" FontSize="9"
                                       TextColor="#34D990"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Select" FontFamily="Nunito" FontSize="11"
                                   TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{DynamicResource ThHintBg}"
                                    Stroke="{DynamicResource ThHintStroke}"
                                    WidthRequest="22" HeightRequest="22">
                                <Label Text="B" FontFamily="NunitoExtraBold" FontSize="9"
                                       TextColor="#FF6B9D"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Back / Cancel" FontFamily="Nunito" FontSize="11"
                                   TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
