<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.SettingsPage"
             Title="Settings"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource ThSettingsBg}">

    <ScrollView Padding="16" BackgroundColor="{DynamicResource ThSettingsBg}">
        <VerticalStackLayout Spacing="12">

            <!-- Gamepad hint -->
            <Label Text="↕ navigate  ◀▶ change  A toggle  B back"
                   FontSize="10" TextColor="{DynamicResource ThTextDim}"
                   HorizontalOptions="End" />

            <!-- Language -->
            <Border x:Name="Row_Language" StyleId="Pick:Language"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Display Language"
                           FontAttributes="Bold" FontSize="15"
                           TextColor="{DynamicResource ThTextPrimary}" />
                    <Label Text="Affects species, move, and ability names. Takes effect when reopening pages."
                           FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    <Picker x:Name="LanguagePicker"
                            SelectedIndexChanged="OnLanguageChanged"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource ThTextPrimary}" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Shiny sprites -->
            <Border x:Name="Row_Shiny" StyleId="Toggle"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Show Shiny Sprites"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label Text="Display alternate colour sprites for shiny Pokémon."
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" x:Name="ShinySwitch"
                            Toggled="OnShinySwitchToggled" VerticalOptions="Center" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Radar adaptive scale -->
            <Border x:Name="Row_Radar" StyleId="Toggle"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Adaptive Radar Scale"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label Text="Scale the stat chart to the Pokémon's best stat so weaker Pokémon fill more of the graph."
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" x:Name="RadarAdaptiveSwitch"
                            Toggled="OnRadarAdaptiveToggled" VerticalOptions="Center" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Manage Folders -->
            <Border x:Name="Row_Folders" StyleId="Navigate"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Manage Save Folders/Files"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label Text="Add or remove folders scanned for save files on startup."
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="20"
                           TextColor="{DynamicResource ThAccent}"
                           VerticalOptions="Center" Margin="8,0,0,0" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Legality badges -->
            <Border x:Name="Row_Legality" StyleId="Toggle"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Show Legality Badges"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label Text="Display a green/red dot on each Pokémon in the box view."
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" x:Name="LegalitySwitch"
                            Toggled="OnLegalitySwitchToggled" VerticalOptions="Center" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Theme -->
            <Border x:Name="Row_Theme" StyleId="Toggle"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Light Theme"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label Text="Switch to a light Nintendo-style appearance."
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" x:Name="ThemeSwitch"
                            Toggled="OnThemeSwitchToggled" VerticalOptions="Center" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="{DynamicResource ThDivider}" />

            <!-- Sprite cache download -->
            <Border x:Name="Row_Sprites"
                    BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSpriteDownloadTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                        <Label Text="Download All Sprites"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource ThTextPrimary}" />
                        <Label x:Name="SpriteStatusLabel"
                               Text="~120 MB · caches HOME sprites for all Pokémon"
                               FontSize="12" TextColor="{DynamicResource ThTextSecondary}" />
                    </VerticalStackLayout>
                    <Grid Grid.Column="1" WidthRequest="52" HeightRequest="52"
                          VerticalOptions="Center" HorizontalOptions="End">
                        <skia:SKCanvasView x:Name="SpriteRingCanvas"
                                           PaintSurface="OnSpriteRingPaint"
                                           WidthRequest="52" HeightRequest="52" />
                        <Label x:Name="SpriteRingLabel"
                               FontFamily="NunitoBold" FontSize="10"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{DynamicResource ThTextPrimary}" />
                    </Grid>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
