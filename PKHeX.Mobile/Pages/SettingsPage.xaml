<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PKHeX.Mobile.Pages.SettingsPage"
             Title="Settings"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B0F1E">

    <ScrollView Padding="16" BackgroundColor="#0B0F1E">
        <VerticalStackLayout Spacing="12">

            <!-- Gamepad hint -->
            <Label Text="↕ navigate  ◀▶ change  A toggle  B back"
                   FontSize="10" TextColor="#404060"
                   HorizontalOptions="End" />

            <!-- Language -->
            <Border x:Name="Row_Language" Tag="Pick:Language"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Display Language"
                           FontAttributes="Bold" FontSize="15"
                           TextColor="#EEEEFF" />
                    <Label Text="Affects species, move, and ability names. Takes effect when reopening pages."
                           FontSize="12" TextColor="#8888BB" />
                    <Picker x:Name="LanguagePicker"
                            SelectedIndexChanged="OnLanguageChanged"
                            BackgroundColor="Transparent" TextColor="White" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="#1E2D45" />

            <!-- Shiny sprites -->
            <Border x:Name="Row_Shiny" Tag="Toggle"
                    BackgroundColor="#111827" Stroke="Transparent"
                    StrokeShape="RoundRectangle 6" Padding="12,10">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Show Shiny Sprites"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="#EEEEFF" />
                        <Label Text="Display alternate colour sprites for shiny Pokémon."
                               FontSize="12" TextColor="#8888BB" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" x:Name="ShinySwitch"
                            Toggled="OnShinySwitchToggled" VerticalOptions="Center" />
                </Grid>
            </Border>

            <BoxView HeightRequest="1" Color="#1E2D45" />

            <!-- Legality (read-only / disabled) -->
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Show Legality Badge"
                           FontAttributes="Bold" FontSize="15"
                           TextColor="#EEEEFF" />
                    <Label Text="Display a ✓/✗ legality indicator on each Pokémon in the box view. (Phase 5)"
                           FontSize="12" TextColor="#8888BB" />
                </VerticalStackLayout>
                <Switch Grid.Column="1" x:Name="LegalitySwitch"
                        IsEnabled="False" VerticalOptions="Center" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
