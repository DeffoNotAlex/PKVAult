<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PKHeX.Mobile.Pages.FolderManagerPage"
             Title="Manage Save Folders/Files"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource ThSettingsBg}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16"
          BackgroundColor="{DynamicResource ThSettingsBg}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,12,0,8">
            <Button Grid.Column="0" Text="← Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{DynamicResource ThAccent}"
                    FontFamily="NunitoBold" FontSize="14" Padding="0,6" />
            <Label Grid.Column="1" Text="Save Folders / Files"
                   FontFamily="NunitoBold" FontSize="20"
                   TextColor="{DynamicResource ThTextPrimary}"
                   VerticalOptions="Center" HorizontalOptions="Center" />
        </Grid>

        <!-- Gamepad hint -->
        <Label Grid.Row="1"
               Text="↕ scroll  X remove  L add folder  R add file  B back"
               FontSize="10" TextColor="{DynamicResource ThTextDim}"
               HorizontalOptions="End" Margin="0,0,0,8" />

        <!-- Directory/file list -->
        <CollectionView x:Name="DirList" Grid.Row="2"
                        SelectionMode="Single"
                        BackgroundColor="Transparent">
            <CollectionView.EmptyView>
                <Label Text="No folders or files added yet."
                       TextColor="{DynamicResource ThTextSecondary}" FontSize="14"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       Margin="24,40" HorizontalTextAlignment="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,4" StrokeShape="RoundRectangle 6"
                            BackgroundColor="{DynamicResource ThSettingsRow}"
                            Stroke="Transparent" Padding="12,10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="{Binding Icon}"
                                   FontSize="16" VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="1"
                                   Text="{Binding Label}"
                                   TextColor="{DynamicResource ThTextPrimary}"
                                   FontSize="13"
                                   LineBreakMode="MiddleTruncation"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="2" Text="✕"
                                    Clicked="OnRemoveClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}"
                                    TextColor="#FF6060"
                                    FontSize="12" Padding="10,6"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Add buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,12">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{DynamicResource ThNavBtnBg}"
                    Stroke="{DynamicResource ThAccent}" Padding="0">
                <Button Text="📁  Add Folder"
                        Clicked="OnAddFolderClicked"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource ThAccentLight}"
                        FontFamily="NunitoBold" FontSize="15"
                        Padding="0,14" HorizontalOptions="Fill" />
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{DynamicResource ThNavBtnBg}"
                    Stroke="{DynamicResource ThAccent}" Padding="0">
                <Button Text="📄  Add File"
                        Clicked="OnAddFileClicked"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource ThAccentLight}"
                        FontFamily="NunitoBold" FontSize="15"
                        Padding="0,14" HorizontalOptions="Fill" />
            </Border>
        </Grid>

    </Grid>

</ContentPage>
