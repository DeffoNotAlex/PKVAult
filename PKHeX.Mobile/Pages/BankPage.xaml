<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:theme="clr-namespace:PKHeX.Mobile.Theme"
             x:Class="PKHeX.Mobile.Pages.BankPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource ThPageBg}">

    <Grid x:Name="RootGrid" RowDefinitions="Auto,Auto,*,Auto"
          BackgroundColor="{DynamicResource ThPageBg}">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="52,*,52"
              BackgroundColor="{DynamicResource ThCardBg}" Padding="4,8">
            <Button Grid.Column="0" x:Name="PrevBankBtn"
                    Text="{x:Static theme:Ph.CaretLeft}"
                    FontFamily="Phosphor"
                    Clicked="OnPrevBox"
                    BackgroundColor="{DynamicResource ThNavBtnBg}"
                    TextColor="White"
                    FontSize="18" Padding="0" />
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="1">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoxHeaderTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label x:Name="BankNameLabel"
                       TextColor="{DynamicResource ThTextPrimary}" FontSize="16" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label x:Name="BoxIndexLabel"
                       TextColor="{DynamicResource ThTextHint}" FontSize="10"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
            <Button Grid.Column="2" x:Name="NextBankBtn"
                    Text="{x:Static theme:Ph.CaretRight}"
                    FontFamily="Phosphor"
                    Clicked="OnNextBox"
                    BackgroundColor="{DynamicResource ThNavBtnBg}"
                    TextColor="White"
                    FontSize="18" Padding="0" />
        </Grid>

        <!-- ── Mode banner ── -->
        <Border Grid.Row="1" x:Name="ModeBanner"
                BackgroundColor="#0D1A0D" Stroke="Transparent"
                Padding="10,6" IsVisible="False">
            <Label x:Name="ModeLabel"
                   TextColor="#44CC66" FontSize="13" FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </Border>

        <!-- ── Bank grid ── -->
        <skia:SKCanvasView Grid.Row="2" x:Name="BankCanvas"
                           PaintSurface="OnBankPaintSurface">
            <skia:SKCanvasView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBankTapped" />
            </skia:SKCanvasView.GestureRecognizers>
        </skia:SKCanvasView>

        <!-- ── Info bar ── -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto"
              BackgroundColor="{DynamicResource ThCardBg}" Padding="12,6">
            <Label x:Name="HoverLabel"
                   TextColor="{DynamicResource ThTextSecondary}" FontSize="12"
                   VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="R-stick: box  L1/R1: swap  Y: grab  A: drop  ⊙: rename  B: back"
                   TextColor="{DynamicResource ThTextHint}" FontSize="9"
                   VerticalOptions="Center" />
        </Grid>

        <!-- ── Pokémon picker overlay (A on empty slot) ── -->
        <Grid x:Name="PickerOverlay"
              Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="#CC000020">
            <Border HorizontalOptions="Center" VerticalOptions="Center"
                    BackgroundColor="{DynamicResource ThActionMenuPanel}"
                    Stroke="{DynamicResource ThActionMenuStroke}"
                    StrokeShape="RoundRectangle 16"
                    Padding="0"
                    MinimumWidthRequest="300"
                    MaximumWidthRequest="440">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <!-- Title -->
                    <Label Grid.Row="0"
                           Text="Choose any Pokémon"
                           FontFamily="NunitoBold" FontSize="13"
                           TextColor="{DynamicResource ThTextPrimary}"
                           HorizontalOptions="Center"
                           Margin="20,14,20,8"/>
                    <!-- List -->
                    <ScrollView Grid.Row="1" x:Name="PickerScroll"
                                MaximumHeightRequest="400">
                        <VerticalStackLayout x:Name="PickerList"
                                             Spacing="3" Padding="12,4"/>
                    </ScrollView>
                    <!-- Hints -->
                    <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center"
                                           Spacing="16" Padding="0,6,0,12">
                        <HorizontalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{DynamicResource ThHintBg}"
                                    Stroke="{DynamicResource ThHintStroke}"
                                    WidthRequest="22" HeightRequest="22">
                                <Label Text="A" FontFamily="NunitoExtraBold" FontSize="9"
                                       TextColor="#34D990"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Deposit" FontFamily="Nunito" FontSize="11"
                                   TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{DynamicResource ThHintBg}"
                                    Stroke="{DynamicResource ThHintStroke}"
                                    WidthRequest="22" HeightRequest="22">
                                <Label Text="B" FontFamily="NunitoExtraBold" FontSize="9"
                                       TextColor="#FF6B9D"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Cancel" FontFamily="Nunito" FontSize="11"
                                   TextColor="{DynamicResource ThTextDim}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
