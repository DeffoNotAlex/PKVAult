<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.PkmEditorPage"
             Title="Edit Pokémon"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource ThSettingsBg}">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="QRButton" Text="QR" Clicked="OnQRClicked" />
        <ToolbarItem Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="RootGrid" RowDefinitions="Auto,Auto,*,Auto" Padding="0" BackgroundColor="{DynamicResource ThSettingsBg}">

        <!-- Row 0: Header: sprite + species/level + back button -->
        <Grid x:Name="HeaderPanel" Grid.Row="0" ColumnDefinitions="80,*,Auto" Padding="8"
              BackgroundColor="{DynamicResource ThSettingsBg}">
            <skia:SKCanvasView Grid.Column="0"
                               x:Name="SpriteCanvas"
                               WidthRequest="68" HeightRequest="56"
                               PaintSurface="OnSpritePaint" />
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="8,0,0,0">
                <Label x:Name="SpeciesLabel" FontSize="18" FontAttributes="Bold"
                       TextColor="{DynamicResource ThTextPrimary}" />
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label x:Name="SubtitleLabel" FontSize="13" TextColor="{DynamicResource ThTextSecondary}" />
                    <Label x:Name="LegalityBadge" FontSize="13" FontAttributes="Bold" Text="" />
                </HorizontalStackLayout>
                <Label Text="↕ row  ◀▶ change  A keyboard  L/R tabs  B back  ▶ save"
                       FontSize="9" TextColor="{DynamicResource ThTextDim}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                  Spacing="4" Margin="0,0,4,0">
                <Button Text="← Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThAccentLight}"
                        FontSize="13" Padding="14,8" />
            </VerticalStackLayout>
        </Grid>

        <!-- Row 1: Tab bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="0"
              BackgroundColor="{DynamicResource ThSettingsBg}">
            <Button x:Name="TabStats"  Grid.Column="0" Text="Stats"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThAccent}" TextColor="{DynamicResource ThTextPrimary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabMoves" Grid.Column="1" Text="Moves"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextSecondary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabMet"   Grid.Column="2" Text="Met"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextSecondary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabOT"    Grid.Column="3" Text="OT"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextSecondary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabMisc"  Grid.Column="4" Text="Misc"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextSecondary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabLegal" Grid.Column="5" Text="⚖"
                    Clicked="OnTabClicked"
                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextSecondary}"
                    FontSize="12" Padding="0,8" CornerRadius="0" />
        </Grid>

        <!-- Row 2: Scrollable content panels (only one visible at a time) -->
        <ScrollView x:Name="TabScrollView" Grid.Row="2" Padding="12" BackgroundColor="{DynamicResource ThSettingsBg}">
            <Grid>

                <!-- ── STATS ── -->
                <VerticalStackLayout x:Name="StatsPanel" Spacing="4">

                    <Border x:Name="Row_Nickname" StyleId="Text"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Nickname"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Entry Grid.Column="1" x:Name="NicknameEntry"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Level" StyleId="Step:Level"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Level"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:Level"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="LevelEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:Level"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Nature" StyleId="Pick:Nature"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Nature"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Nature"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="NaturePicker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Nature"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Ability"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Ability"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Label Grid.Column="1" x:Name="AbilityLabel"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Gender" StyleId="Pick:Gender"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Gender"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Gender"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="GenderPicker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Gender"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Shiny" StyleId="Toggle"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Shiny"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Switch Grid.Column="1" x:Name="ShinySwitch" HorizontalOptions="Start" />
                        </Grid>
                    </Border>

                    <!-- IVs -->
                    <Label Text="IVs  (0 – 31)" FontAttributes="Bold"
                           TextColor="{DynamicResource ThAccent}" Margin="0,8,0,0" />

                    <Border x:Name="Row_IvHp" StyleId="Step:IV_HP"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="HP"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_HP"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvHpEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_HP"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvAtk" StyleId="Step:IV_ATK"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Atk"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_ATK"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvAtkEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_ATK"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvDef" StyleId="Step:IV_DEF"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Def"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_DEF"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvDefEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_DEF"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvSpA" StyleId="Step:IV_SPA"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpA"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_SPA"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvSpaEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_SPA"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvSpD" StyleId="Step:IV_SPD"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpD"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_SPD"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvSpdEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_SPD"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvSpe" StyleId="Step:IV_SPE"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Spe"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:IV_SPE"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvSpeEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:IV_SPE"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <!-- EVs -->
                    <Label Text="EVs  (0 – 252)" FontAttributes="Bold"
                           TextColor="{DynamicResource ThAccent}" Margin="0,8,0,0" />

                    <Border x:Name="Row_EvHp" StyleId="Step:EV_HP"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="HP"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_HP"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvHpEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_HP"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvAtk" StyleId="Step:EV_ATK"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Atk"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_ATK"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvAtkEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_ATK"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvDef" StyleId="Step:EV_DEF"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Def"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_DEF"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvDefEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_DEF"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpA" StyleId="Step:EV_SPA"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpA"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_SPA"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpaEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_SPA"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpD" StyleId="Step:EV_SPD"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpD"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_SPD"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpdEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_SPD"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpe" StyleId="Step:EV_SPE"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Spe"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:EV_SPE"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpeEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:EV_SPE"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── MOVES ── -->
                <VerticalStackLayout x:Name="MovesPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_Move1" StyleId="Pick:Move1"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 1"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Move1"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move1Picker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Move1"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Move2" StyleId="Pick:Move2"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 2"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Move2"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move2Picker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Move2"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Move3" StyleId="Pick:Move3"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 3"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Move3"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move3Picker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Move3"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Move4" StyleId="Pick:Move4"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 4"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Move4"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move4Picker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Move4"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── MET ── -->
                <VerticalStackLayout x:Name="MetPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_MetLevel" StyleId="Step:MetLevel"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,38,*,38">
                            <Label Grid.Column="0" Text="Met Level"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:MetLevel"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="MetLevelEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:MetLevel"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Ball"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Ball"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Label Grid.Column="1" x:Name="BallLabel"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_MetLoc"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Met Location"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Label Grid.Column="1" x:Name="MetLocationLabel"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_OriginGame"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Origin Game"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Label Grid.Column="1" x:Name="OriginGameLabel"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── OT ── -->
                <VerticalStackLayout x:Name="OTPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_OTName" StyleId="Text"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,*">
                            <Label Grid.Column="0" Text="OT Name"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Entry Grid.Column="1" x:Name="OTNameEntry"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_TID" StyleId="Step:TID"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="TID"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:TID"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="TIDEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:TID"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_SID" StyleId="Step:SID"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="SID"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Step:SID"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="SIDEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}"
                                   PlaceholderColor="{DynamicResource ThTextHint}" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" StyleId="Step:SID"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Language" StyleId="Pick:Language"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="Language"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Button Grid.Column="1" Text="◀" StyleId="Pick:Language"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="LanguagePicker"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="3" Text="▶" StyleId="Pick:Language"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThTextPrimary}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── MISC ── -->
                <VerticalStackLayout x:Name="MiscPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_Happiness" StyleId="Step:Happiness"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*,Auto,Auto">
                            <Label Grid.Column="0" Text="Happiness"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Entry Grid.Column="1" x:Name="HappinessEntry"
                                   Keyboard="Numeric" BackgroundColor="Transparent"
                                   TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="2" Text="−" StyleId="Step:Happiness"
                                    Clicked="OnStepDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThAccentLight}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Button Grid.Column="3" Text="+" StyleId="Step:Happiness"
                                    Clicked="OnStepInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThAccentLight}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_HeldItem" StyleId="Pick:HeldItem"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*,Auto,Auto">
                            <Label Grid.Column="0" Text="Held Item"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Picker Grid.Column="1" x:Name="HeldItemPicker"
                                    BackgroundColor="Transparent"
                                    TextColor="{DynamicResource ThTextPrimary}" />
                            <Button Grid.Column="2" Text="−" StyleId="Pick:HeldItem"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThAccentLight}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Button Grid.Column="3" Text="+" StyleId="Pick:HeldItem"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="{DynamicResource ThNavBtnBg}" TextColor="{DynamicResource ThAccentLight}"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_PID" StyleId="Text"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="PID (hex)"
                                   VerticalOptions="Center" TextColor="{DynamicResource ThTextSecondary}" />
                            <Entry Grid.Column="1" x:Name="PIDEntry"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource ThTextPrimary}" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Markings" StyleId="Text"
                            BackgroundColor="{DynamicResource ThSettingsRow}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Markings" TextColor="{DynamicResource ThTextSecondary}" />
                            <HorizontalStackLayout Spacing="12">
                                <CheckBox x:Name="MarkCircle"   Color="{DynamicResource ThAccentLight}" />
                                <Label Text="●" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                                <CheckBox x:Name="MarkTriangle" Color="{DynamicResource ThAccentLight}" />
                                <Label Text="▲" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                                <CheckBox x:Name="MarkSquare"   Color="{DynamicResource ThAccentLight}" />
                                <Label Text="■" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                                <CheckBox x:Name="MarkHeart"    Color="{DynamicResource ThAccentLight}" />
                                <Label Text="♥" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                                <CheckBox x:Name="MarkStar"     Color="{DynamicResource ThAccentLight}" />
                                <Label Text="★" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                                <CheckBox x:Name="MarkDiamond"  Color="{DynamicResource ThAccentLight}" />
                                <Label Text="◆" VerticalOptions="Center" TextColor="{DynamicResource ThTextPrimary}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ── LEGAL ── -->
                <VerticalStackLayout x:Name="LegalPanel" IsVisible="False" Spacing="6">
                    <Label x:Name="LegalityVerdictLabel"
                           FontSize="22" FontAttributes="Bold"
                           HorizontalOptions="Center" Margin="0,20,0,12" />
                    <VerticalStackLayout x:Name="LegalityIssuesList" Spacing="3" Padding="4,0" />
                </VerticalStackLayout>

            </Grid>
        </ScrollView>

        <!-- Row 3: Save button fixed at bottom -->
        <Button Grid.Row="3"
                Text="💾 Save Changes"
                Clicked="OnSaveClicked"
                BackgroundColor="{DynamicResource ThExportMenuBg}" TextColor="{DynamicResource ThExportMenuText}"
                FontSize="15" FontAttributes="Bold"
                Padding="0,14"
                Margin="12,8" CornerRadius="8" />

    </Grid>
</ContentPage>
