<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.PkmEditorPage"
             Title="Edit Pokémon">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="QRButton" Text="QR" Clicked="OnQRClicked" />
        <ToolbarItem Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Header: sprite + species/level -->
        <Grid Grid.Row="0" ColumnDefinitions="80,*" Padding="8"
              BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
            <skia:SKCanvasView Grid.Column="0"
                               x:Name="SpriteCanvas"
                               WidthRequest="68" HeightRequest="56"
                               PaintSurface="OnSpritePaint" />
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="8,0,0,0">
                <Label x:Name="SpeciesLabel" FontSize="18" FontAttributes="Bold" />
                <Label x:Name="SubtitleLabel" FontSize="13" Opacity="0.7" />
            </VerticalStackLayout>
        </Grid>

        <!-- Tab bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="1"
              BackgroundColor="{AppThemeBinding Light=#CCCCCC, Dark=#333333}">
            <Button x:Name="TabStats"  Grid.Column="0" Text="Stats"  Clicked="OnTabClicked" FontSize="13" Padding="0,8" />
            <Button x:Name="TabMoves" Grid.Column="1" Text="Moves" Clicked="OnTabClicked" FontSize="13" Padding="0,8" />
            <Button x:Name="TabMet"   Grid.Column="2" Text="Met"   Clicked="OnTabClicked" FontSize="13" Padding="0,8" />
            <Button x:Name="TabOT"    Grid.Column="3" Text="OT"    Clicked="OnTabClicked" FontSize="13" Padding="0,8" />
        </Grid>

        <!-- Scrollable content panels (only one visible at a time) -->
        <ScrollView Grid.Row="2" Padding="12">
            <Grid>

                <!-- ── STATS ── -->
                <VerticalStackLayout x:Name="StatsPanel" Spacing="10">

                    <Grid ColumnDefinitions="90,*" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Nickname" VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" x:Name="NicknameEntry" />
                    </Grid>

                    <Grid ColumnDefinitions="90,*">
                        <Label Grid.Column="0" Text="Level" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="LevelEntry" Keyboard="Numeric" />
                    </Grid>

                    <Grid ColumnDefinitions="90,*">
                        <Label Grid.Column="0" Text="Nature" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="NaturePicker" />
                    </Grid>

                    <Grid ColumnDefinitions="90,*">
                        <Label Grid.Column="0" Text="Ability" VerticalOptions="Center" />
                        <Label Grid.Column="1" x:Name="AbilityLabel" VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="90,*">
                        <Label Grid.Column="0" Text="Gender" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="GenderPicker" />
                    </Grid>

                    <Grid ColumnDefinitions="90,*">
                        <Label Grid.Column="0" Text="Shiny" VerticalOptions="Center" />
                        <Switch Grid.Column="1" x:Name="ShinySwitch" HorizontalOptions="Start" />
                    </Grid>

                    <!-- IVs -->
                    <Label Text="IVs  (0 – 31)" FontAttributes="Bold" Margin="0,8,0,0" />
                    <Grid ColumnDefinitions="50,*,50,*" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="HP"  VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" x:Name="IvHpEntry"  Keyboard="Numeric" />
                        <Label Grid.Row="0" Grid.Column="2" Text="Atk" VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="3" x:Name="IvAtkEntry" Keyboard="Numeric" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Def" VerticalOptions="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" x:Name="IvDefEntry" Keyboard="Numeric" />
                        <Label Grid.Row="1" Grid.Column="2" Text="SpA" VerticalOptions="Center" />
                        <Entry Grid.Row="1" Grid.Column="3" x:Name="IvSpaEntry" Keyboard="Numeric" />

                        <Label Grid.Row="2" Grid.Column="0" Text="SpD" VerticalOptions="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" x:Name="IvSpdEntry" Keyboard="Numeric" />
                        <Label Grid.Row="2" Grid.Column="2" Text="Spe" VerticalOptions="Center" />
                        <Entry Grid.Row="2" Grid.Column="3" x:Name="IvSpeEntry" Keyboard="Numeric" />
                    </Grid>

                    <!-- EVs -->
                    <Label Text="EVs  (0 – 252)" FontAttributes="Bold" Margin="0,8,0,0" />
                    <Grid ColumnDefinitions="50,*,50,*" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="HP"  VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" x:Name="EvHpEntry"  Keyboard="Numeric" />
                        <Label Grid.Row="0" Grid.Column="2" Text="Atk" VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="3" x:Name="EvAtkEntry" Keyboard="Numeric" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Def" VerticalOptions="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" x:Name="EvDefEntry" Keyboard="Numeric" />
                        <Label Grid.Row="1" Grid.Column="2" Text="SpA" VerticalOptions="Center" />
                        <Entry Grid.Row="1" Grid.Column="3" x:Name="EvSpaEntry" Keyboard="Numeric" />

                        <Label Grid.Row="2" Grid.Column="0" Text="SpD" VerticalOptions="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" x:Name="EvSpdEntry" Keyboard="Numeric" />
                        <Label Grid.Row="2" Grid.Column="2" Text="Spe" VerticalOptions="Center" />
                        <Entry Grid.Row="2" Grid.Column="3" x:Name="EvSpeEntry" Keyboard="Numeric" />
                    </Grid>

                </VerticalStackLayout>

                <!-- ── MOVES ── -->
                <VerticalStackLayout x:Name="MovesPanel" IsVisible="False" Spacing="12">
                    <Grid ColumnDefinitions="60,*">
                        <Label Grid.Column="0" Text="Move 1" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="Move1Picker" />
                    </Grid>
                    <Grid ColumnDefinitions="60,*">
                        <Label Grid.Column="0" Text="Move 2" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="Move2Picker" />
                    </Grid>
                    <Grid ColumnDefinitions="60,*">
                        <Label Grid.Column="0" Text="Move 3" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="Move3Picker" />
                    </Grid>
                    <Grid ColumnDefinitions="60,*">
                        <Label Grid.Column="0" Text="Move 4" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="Move4Picker" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ── MET ── -->
                <VerticalStackLayout x:Name="MetPanel" IsVisible="False" Spacing="10">
                    <Grid ColumnDefinitions="110,*">
                        <Label Grid.Column="0" Text="Met Level" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="MetLevelEntry" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="110,*">
                        <Label Grid.Column="0" Text="Ball" VerticalOptions="Center" />
                        <Label Grid.Column="1" x:Name="BallLabel" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="110,*">
                        <Label Grid.Column="0" Text="Met Location" VerticalOptions="Center" />
                        <Label Grid.Column="1" x:Name="MetLocationLabel" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="110,*">
                        <Label Grid.Column="0" Text="Origin Game" VerticalOptions="Center" />
                        <Label Grid.Column="1" x:Name="OriginGameLabel" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ── OT ── -->
                <VerticalStackLayout x:Name="OTPanel" IsVisible="False" Spacing="10">
                    <Grid ColumnDefinitions="100,*">
                        <Label Grid.Column="0" Text="OT Name" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="OTNameEntry" />
                    </Grid>
                    <Grid ColumnDefinitions="100,*">
                        <Label Grid.Column="0" Text="TID" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="TIDEntry" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="100,*">
                        <Label Grid.Column="0" Text="SID" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="SIDEntry" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="100,*">
                        <Label Grid.Column="0" Text="Language" VerticalOptions="Center" />
                        <Picker Grid.Column="1" x:Name="LanguagePicker" />
                    </Grid>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>
