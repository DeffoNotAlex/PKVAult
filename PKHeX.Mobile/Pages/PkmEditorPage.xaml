                            <Button Grid.Column="3" Text="▶" Tag="Step:IV_SPA"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvSpD" Tag="Step:IV_SPD"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpD"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:IV_SPD"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvSpdEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:IV_SPD"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_IvSpe" Tag="Step:IV_SPE"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Spe"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:IV_SPE"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvSpeEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:IV_SPE"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <!-- EVs -->
                    <Label Text="EVs  (0 – 252)" FontAttributes="Bold"
                           TextColor="#4F80FF" Margin="0,8,0,0" />

                    <Border x:Name="Row_EvHp" Tag="Step:EV_HP"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="HP"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_HP"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvHpEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_HP"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvAtk" Tag="Step:EV_ATK"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Atk"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_ATK"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvAtkEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_ATK"
