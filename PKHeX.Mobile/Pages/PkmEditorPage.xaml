                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Def"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_DEF"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvDefEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_DEF"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpA" Tag="Step:EV_SPA"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpA"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_SPA"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpaEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_SPA"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpD" Tag="Step:EV_SPD"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="SpD"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_SPD"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpdEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_SPD"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_EvSpe" Tag="Step:EV_SPE"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Spe"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:EV_SPE"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="EvSpeEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:EV_SPE"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── MOVES ── -->
                <VerticalStackLayout x:Name="MovesPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_Move1" Tag="Pick:Move1"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 1"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Move1"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move1Picker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Move1"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Move2" Tag="Pick:Move2"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 2"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Move2"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move2Picker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Move2"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Move3" Tag="Pick:Move3"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="60,38,*,38">
                            <Label Grid.Column="0" Text="Move 3"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Move3"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
