                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="Move4Picker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Move4"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── MET ── -->
                <VerticalStackLayout x:Name="MetPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_MetLevel" Tag="Step:MetLevel"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,38,*,38">
                            <Label Grid.Column="0" Text="Met Level"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:MetLevel"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="MetLevelEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:MetLevel"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Ball"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Ball"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Label Grid.Column="1" x:Name="BallLabel"
                                   VerticalOptions="Center" TextColor="#EEEEFF" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_MetLoc"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Met Location"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Label Grid.Column="1" x:Name="MetLocationLabel"
                                   VerticalOptions="Center" TextColor="#EEEEFF" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_OriginGame"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="110,*">
                            <Label Grid.Column="0" Text="Origin Game"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Label Grid.Column="1" x:Name="OriginGameLabel"
                                   VerticalOptions="Center" TextColor="#EEEEFF" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── OT ── -->
                <VerticalStackLayout x:Name="OTPanel" IsVisible="False" Spacing="4">

                    <Border x:Name="Row_OTName" Tag="Text"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,*">
                            <Label Grid.Column="0" Text="OT Name"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Entry Grid.Column="1" x:Name="OTNameEntry"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_TID" Tag="Step:TID"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="TID"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:TID"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="TIDEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:TID"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_SID" Tag="Step:SID"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="SID"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:SID"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="SIDEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:SID"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Language" Tag="Pick:Language"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="100,38,*,38">
                            <Label Grid.Column="0" Text="Language"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Language"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="LanguagePicker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Language"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

            </Grid>
        </ScrollView>

        <!-- Row 3: Save button fixed at bottom -->
        <Button Grid.Row="3"
                Text="💾 Save Changes"
                Clicked="OnSaveClicked"
                BackgroundColor="#2D1B69" TextColor="#C0A0FF"
                FontSize="15" FontAttributes="Bold"
                Padding="0,14"
                Margin="12,8" CornerRadius="8" />

    </Grid>
</ContentPage>
