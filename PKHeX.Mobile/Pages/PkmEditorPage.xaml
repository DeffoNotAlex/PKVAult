<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="PKHeX.Mobile.Pages.PkmEditorPage"
             Title="Edit Pokémon"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B0F1E">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="QRButton" Text="QR" Clicked="OnQRClicked" />
        <ToolbarItem Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="0" BackgroundColor="#0B0F1E">

        <!-- Row 0: Header: sprite + species/level + back button -->
        <Grid Grid.Row="0" ColumnDefinitions="80,*,Auto" Padding="8"
              BackgroundColor="#0D1121">
            <skia:SKCanvasView Grid.Column="0"
                               x:Name="SpriteCanvas"
                               WidthRequest="68" HeightRequest="56"
                               PaintSurface="OnSpritePaint" />
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="8,0,0,0">
                <Label x:Name="SpeciesLabel" FontSize="18" FontAttributes="Bold"
                       TextColor="#EEEEFF" />
                <Label x:Name="SubtitleLabel" FontSize="13" TextColor="#8888BB" />
                <Label Text="↕ row  ◀▶ change  A keyboard  L/R tabs  B back  ▶ save"
                       FontSize="9" TextColor="#404060" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                  Spacing="4" Margin="0,0,4,0">
                <Button Text="← Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="#1D3A70" TextColor="#A0C0FF"
                        FontSize="13" Padding="14,8" />
            </VerticalStackLayout>
        </Grid>

        <!-- Row 1: Tab bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="0"
              BackgroundColor="#0B0F1E">
            <Button x:Name="TabStats"  Grid.Column="0" Text="Stats"
                    Clicked="OnTabClicked"
                    BackgroundColor="#4F80FF" TextColor="White"
                    FontSize="13" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabMoves" Grid.Column="1" Text="Moves"
                    Clicked="OnTabClicked"
                    BackgroundColor="#1A2035" TextColor="#8888BB"
                    FontSize="13" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabMet"   Grid.Column="2" Text="Met"
                    Clicked="OnTabClicked"
                    BackgroundColor="#1A2035" TextColor="#8888BB"
                    FontSize="13" Padding="0,8" CornerRadius="0" />
            <Button x:Name="TabOT"    Grid.Column="3" Text="OT"
                    Clicked="OnTabClicked"
                    BackgroundColor="#1A2035" TextColor="#8888BB"
                    FontSize="13" Padding="0,8" CornerRadius="0" />
        </Grid>

        <!-- Row 2: Scrollable content panels (only one visible at a time) -->
        <ScrollView x:Name="TabScrollView" Grid.Row="2" Padding="12" BackgroundColor="#0B0F1E">
            <Grid>

                <!-- ── STATS ── -->
                <VerticalStackLayout x:Name="StatsPanel" Spacing="4">

                    <Border x:Name="Row_Nickname" Tag="Text"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Nickname"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Entry Grid.Column="1" x:Name="NicknameEntry"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Level" Tag="Step:Level"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Level"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:Level"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="LevelEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:Level"
                                    Clicked="OnStepInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Nature" Tag="Pick:Nature"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Nature"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Nature"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="NaturePicker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Nature"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Ability"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Ability"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Label Grid.Column="1" x:Name="AbilityLabel"
                                   VerticalOptions="Center" TextColor="#EEEEFF" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Gender" Tag="Pick:Gender"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="Gender"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Pick:Gender"
                                    Clicked="OnPickerDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Picker Grid.Column="2" x:Name="GenderPicker"
                                    BackgroundColor="Transparent" TextColor="White" />
                            <Button Grid.Column="3" Text="▶" Tag="Pick:Gender"
                                    Clicked="OnPickerInc"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                        </Grid>
                    </Border>

                    <Border x:Name="Row_Shiny" Tag="Toggle"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,*">
                            <Label Grid.Column="0" Text="Shiny"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Switch Grid.Column="1" x:Name="ShinySwitch" HorizontalOptions="Start" />
                        </Grid>
                    </Border>

                    <!-- IVs -->
                    <Label Text="IVs  (0 – 31)" FontAttributes="Bold"
                           TextColor="#4F80FF" Margin="0,8,0,0" />

                    <Border x:Name="Row_IvHp" Tag="Step:IV_HP"
                            BackgroundColor="#111827" Stroke="Transparent"
                            StrokeShape="RoundRectangle 6" Padding="8,6">
                        <Grid ColumnDefinitions="90,38,*,38">
                            <Label Grid.Column="0" Text="HP"
                                   VerticalOptions="Center" TextColor="#8888BB" />
                            <Button Grid.Column="1" Text="◀" Tag="Step:IV_HP"
                                    Clicked="OnStepDec"
                                    BackgroundColor="#1A2035" TextColor="White"
                                    FontSize="12" Padding="0" WidthRequest="38" />
                            <Entry Grid.Column="2" x:Name="IvHpEntry" Keyboard="Numeric"
                                   BackgroundColor="Transparent" TextColor="White"
                                   PlaceholderColor="#556080" HorizontalTextAlignment="Center" />
                            <Button Grid.Column="3" Text="▶" Tag="Step:IV_HP"
